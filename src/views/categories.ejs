<main class="page-shell">
  <section class="hero hero--page">
    <div class="hero__inner">
      <div class="hero-copy">
        <p class="eyebrow eyebrow--page">Browse by type</p>
        <h1><%= title %></h1>
        <p class="hero-lead">Use the categories below to sort opportunities by the kind of impact you want to make.</p>
      </div>
    </div>
  </section>

  <section class="category-grid" aria-label="Service project categories">
    <% categories.forEach((category) => { %>
      <a class="category-card" href="/category/<%= category.category_id %>">
        <div>
          <h2><%= category.name %></h2>
          <p><%= category.description %></p>
        </div>
      </a>
    <% }) %>
  </section>
</main>
