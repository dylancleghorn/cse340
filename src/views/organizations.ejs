<main class="page-shell">
  <section class="hero hero--page">
    <div class="hero__inner">
      <div class="hero-copy">
        <p class="eyebrow eyebrow--page">Partners</p>
        <h1><%= title %></h1>
        <p class="hero-lead">Here are a few of our partner organizations:</p>
      </div>
    </div>
  </section>

  <section class="org-grid" aria-label="Partner organizations">
    <% organizations.forEach((organization) => { %>
      <article class="org-card">
        <img class="org-logo" src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
        <div>
          <h2><%= organization.name %></h2>
          <p><%= organization.contact_email %></p>
          <p><%= organization.description %></p>
        </div>
      </article>
    <% }) %>
  </section>
</main>
