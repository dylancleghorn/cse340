<main class="page-shell">
  <section class="hero hero--page">
    <div class="hero__inner">
      <div class="hero-copy">
        <p class="eyebrow eyebrow--page">Projects</p>
        <h1><%= title %></h1>
        <p class="hero-lead">Browse active volunteer opportunities from our partner organizations.</p>
      </div>
    </div>
  </section>

  <section class="project-stack" aria-label="Service projects">
    <% projects.forEach((project) => { %>
      <article class="project-card">
        <strong><%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' }) %>: <%= project.title %> (<%= project.organization_name %>)</strong>
        <p><%= project.description %></p>
        <p><%= project.location %></p>
      </article>
    <% }) %>
  </section>
</main>
